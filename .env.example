# ============================================================
# VARIÁVEIS DE AMBIENTE — copie este arquivo para ".env.local"
# e preencha os valores. Na Vercel, cadastre em:
# Settings → Environment Variables
# ============================================================

# Senha para acessar a página /admin (consulta de leads).
# Escolha uma senha forte e não compartilhe.
ADMIN_PASSWORD=troque-esta-senha

# ---------- Supabase (banco de leads) ----------
# Endereço e chave PÚBLICA do projeto (Supabase → Settings → API).
# Podem aparecer no site — a segurança fica no banco (RLS).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Chave SECRETA (service_role) — opcional, só para o painel /admin ler os leads.
# Supabase → Settings → API → service_role. NUNCA com prefixo NEXT_PUBLIC_.
# Sem ela, veja os leads direto pelo painel do Supabase (Table Editor).
SUPABASE_SERVICE_ROLE_KEY=
