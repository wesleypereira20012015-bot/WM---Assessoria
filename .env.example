# ============================================================
# VARIÁVEIS DE AMBIENTE — copie este arquivo para ".env.local"
# e preencha os valores. Na Vercel, cadastre em:
# Settings → Environment Variables
# ============================================================

# Senha para acessar a página /admin (consulta de leads).
# Escolha uma senha forte e não compartilhe.
ADMIN_PASSWORD=troque-esta-senha

# Conexão com o banco Postgres (Neon).
# Na Vercel: Storage → Create Database → Neon → a variável é criada sozinha.
# Sem esta variável, em desenvolvimento os leads são salvos no arquivo .data/leads.json
DATABASE_URL=
